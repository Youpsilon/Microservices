{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@restaurant/shared-types": ["packages/shared-types/src/index.ts"],
      "@restaurant/shared-types/*": ["packages/shared-types/src/*"],
      "@restaurant/amqp-utils": ["packages/amqp-utils/src/index.ts"],
      "@restaurant/amqp-utils/*": ["packages/amqp-utils/src/*"],
      "@restaurant/auth-guard": ["packages/auth-guard/src/index.ts"],
      "@restaurant/auth-guard/*": ["packages/auth-guard/src/*"]
    }
  }
}
