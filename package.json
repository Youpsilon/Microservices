{
  "name": "@restaurant-app/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v; docker compose up -d",
    "dev:auth": "npx ts-node -r tsconfig-paths/register --project packages/auth-service/tsconfig.json packages/auth-service/src/main.ts",
    "dev:menu": "npx ts-node -r tsconfig-paths/register --project packages/menu-service/tsconfig.json packages/menu-service/src/main.ts",
    "dev:order": "npx ts-node -r tsconfig-paths/register --project packages/order-service/tsconfig.json packages/order-service/src/main.ts",
    "dev:kitchen": "npx ts-node -r tsconfig-paths/register --project packages/kitchen-service/tsconfig.json packages/kitchen-service/src/main.ts",
    "dev:delivery": "npx ts-node -r tsconfig-paths/register --project packages/delivery-service/tsconfig.json packages/delivery-service/src/main.ts",
    "dev:gateway": "npx ts-node -r tsconfig-paths/register --project packages/api-gateway/tsconfig.json packages/api-gateway/src/main.ts",
    "dev:web": "npm run dev -w packages/web-client",
    "dev:all": "npx concurrently -n \"auth,menu,order,kitchen,delivery,gateway,web\" -c \"blue,green,magenta,yellow,cyan,white,red\" \"npm:dev:auth\" \"npm:dev:menu\" \"npm:dev:order\" \"npm:dev:kitchen\" \"npm:dev:delivery\" \"npm:dev:gateway\" \"npm:dev:web\""
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.21",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "typeorm": "^1.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@nx/js": "22.7.2",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "^0.2.39",
    "@types/amqplib": "^0.10.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "jest": "^30.4.2",
    "nx": "22.7.2",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2"
  },
  "workspaces": [
    "packages/*"
  ]
}
